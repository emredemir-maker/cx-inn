# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# Comma-separated list of allowed frontend origins (Firebase Hosting URL)
# Example: https://cx-inn-platform.web.app,https://yourdomain.com
ALLOWED_ORIGIN=https://cx-inn-platform.web.app

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (use pooled URL for production)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── Google / Firebase ────────────────────────────────────────────────────────
# Firebase project ID (same as GCP project ID)
FIREBASE_PROJECT_ID=cx-inn-platform

# Firebase Admin SDK service account JSON (base64 encoded OR raw JSON string)
# Generate at: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ─── AI ───────────────────────────────────────────────────────────────────────
# Google Gemini API key
# Generate at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ─── Email ────────────────────────────────────────────────────────────────────
# Gmail SMTP (primary email transport)
# Use a Gmail account dedicated to this app, NOT your personal account
GMAIL_USER=noreply@yourcompany.com

# Gmail App Password (NOT your Gmail login password)
# Generate at: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Resend API key (fallback email transport - optional)
# Get at: https://resend.com/api-keys
RESEND_API_KEY=re_...
